# Database — thay bằng URL thật khi deploy (Neon/Supabase/Railway)
DATABASE_URL=postgresql://postgres:password@localhost:5432/staffos

# JWT Secret — đổi thành chuỗi random dài khi deploy
JWT_SECRET=staffos-dev-secret-change-me

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173
ADMIN_DASHBOARD_URL=http://localhost:5174,http://127.0.0.1:5174

# Platform admin
ADMIN_EMAIL=admin@staffos.vn
ADMIN_PASSWORD=your-admin-password
